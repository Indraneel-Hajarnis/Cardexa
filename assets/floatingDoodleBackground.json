  "usageInstructions": {
    "react_native": {
      "description": "Use with react-native-svg. Place icons at random positions with Animated.Value for floating.",
      "animationCode": "Animated.loop(Animated.sequence([Animated.timing(translateY, { toValue: liftValue, duration: duration, easing: Easing.inOut(Easing.ease), useNativeDriver: true }), Animated.timing(translateY, { toValue: 0, duration: duration, easing: Easing.inOut(Easing.ease), useNativeDriver: true })]))"
    },
    "web_css": {
      "description": "Use SVG icons absolutely positioned. Apply CSS keyframe animation per icon.",
      "animationCode": "@keyframes float { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-14px) rotate(4deg); } }"
    },
    "notes": [
      "Each icon should get a random duration from durationRange for organic feel",
      "Each icon should get a random negative delay so they are out of phase",
      "Opacity and size should be randomized per icon within the given ranges",
      "Place icons in a grid with slight random offset for even coverage",
      "Ensure the icon layer has pointerEvents: 'none' / pointer-events: none so it does not block UI"
    ]
  }
